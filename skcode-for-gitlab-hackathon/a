from fastapi import FastAPI, Request
import requests
import os
from dotenv import load_dotenv
from openai import OpenAI
import base64
import time

load_dotenv()

app = FastAPI()

GITHUB_TOKEN = os.getenv("GITHUB_TOKEN")
client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))

headers = {
    "Authorization": f"token {GITHUB_TOKEN}",
    "Accept": "application/vnd.github.v3+json"
}

@app.get("/")
def home():
    return {"message": "🚀 SK Codes AI Running"}

@app.post("/webhook")
async def github_webhook(request: Request):
    payload = await request.json()

    # Trigger only on PR opened
    if payload.get("action") == "opened":
        repo = payload["repository"]["full_name"]
        pr = payload["pull_request"]
        pr_number = pr["number"]
        base_branch = pr["base"]["ref"]

        print(f"Processing PR #{pr_number} in {repo}")

        # Get changed files
        files_url = pr["url"] + "/files"
        files = requests.get(files_url, headers=headers).json()

        fixes = []
        risk_score = 0

        for file in files:
            filename = file["filename"]
            patch = file.get("patch")

            if not patch:
                continue

            # AI ANALYSIS
            response = client.chat.completions.create(
                model="gpt-4o-mini",
                messages=[
                    {"role": "system", "content": "You are a senior security code reviewer."},
                    {"role": "user", "content": f"""
Analyze this code:
{patch}

1. Find bugs/security issues
2. Give fixed code
3. Give risk level (Low/Medium/High)

Format:
ISSUES:
FIX:
RISK:
"""}
                ]
            )

            result = response.choices[0].message.content
            fixes.append(f"### {filename}\n{result}")

            if "High" in result:
                risk_score += 3
            elif "Medium" in result:
                risk_score += 2
            else:
                risk_score += 1

        # Create new branch
        branch_name = f"sk-fix-{int(time.time())}"

        repo_url = f"https://api.github.com/repos/{repo}"

        # Get base branch SHA
        ref_data = requests.get(
            f"{repo_url}/git/ref/heads/{base_branch}",
            headers=headers
        ).json()

        sha = ref_data["object"]["sha"]

        # Create new branch
        requests.post(
            f"{repo_url}/git/refs",
            headers=headers,
            json={
                "ref": f"refs/heads/{branch_name}",
                "sha": sha
            }
        )

        # Modify files and commit fixes
        for file in files:
            filename = file["filename"]

            # Get file content
            file_data = requests.get(
                f"{repo_url}/contents/{filename}",
                headers=headers
            ).json()

            content = base64.b64decode(file_data["content"]).decode()

            # Ask AI to fix code
            fix_response = client.chat.completions.create(
                model="gpt-4o-mini",
                messages=[
                    {"role": "system", "content": "Fix this code safely."},
                    {"role": "user", "content": content}
                ]
            )

            fixed_code = fix_response.choices[0].message.content

            encoded_content = base64.b64encode(fixed_code.encode()).decode()

            # Commit file
            requests.put(
                f"{repo_url}/contents/{filename}",
                headers=headers,
                json={
                    "message": f"🤖 SK Codes Auto Fix: {filename}",
                    "content": encoded_content,
                    "branch": branch_name,
                    "sha": file_data["sha"]
                }
            )

        # Create Pull Request
        pr_response = requests.post(
            f"{repo_url}/pulls",
            headers=headers,
            json={
                "title": "🤖 SK Codes Auto Fix PR",
                "head": branch_name,
                "base": base_branch,
                "body": f"""
## 🚀 SK Codes AI Auto Fix

### 🔥 Risk Score: {risk_score}

### 📊 Analysis:
{chr(10).join(fixes)}

---
✅ This PR was automatically generated by SK Codes
"""
            }
        )

        print("PR Created:", pr_response.json())

    return {"status": "done"}
